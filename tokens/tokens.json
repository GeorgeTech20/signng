{
  "$description": "SignNG design tokens — DTCG format (W3C Design Tokens 2025.10). primitive -> semantic -> component. Color space: oklch.",
  "primitive": {
    "$type": "color",
    "white": { "$value": "oklch(1 0 0)" },
    "black": { "$value": "oklch(0 0 0)" },
    "neutral": {
      "50": { "$value": "oklch(0.985 0 0)" },
      "100": { "$value": "oklch(0.97 0 0)" },
      "200": { "$value": "oklch(0.922 0 0)" },
      "400": { "$value": "oklch(0.64 0 0)" },
      "500": { "$value": "oklch(0.556 0 0)" },
      "600": { "$value": "oklch(0.46 0 0)" },
      "800": { "$value": "oklch(0.269 0 0)" },
      "900": { "$value": "oklch(0.205 0 0)" },
      "950": { "$value": "oklch(0.145 0 0)" }
    },
    "brand": {
      "400": { "$value": "oklch(0.673 0.182 276.935)" },
      "500": { "$value": "oklch(0.585 0.233 277.117)" },
      "600": { "$value": "oklch(0.511 0.262 276.966)" }
    },
    "red": {
      "500": { "$value": "oklch(0.637 0.237 25.331)" },
      "600": { "$value": "oklch(0.577 0.245 27.325)" }
    }
  },
  "semantic": {
    "$type": "color",
    "light": {
      "background": { "$value": "{primitive.white}" },
      "foreground": { "$value": "{primitive.neutral.950}" },
      "card": { "$value": "{primitive.white}" },
      "card-foreground": { "$value": "{primitive.neutral.950}" },
      "popover": { "$value": "{primitive.white}" },
      "popover-foreground": { "$value": "{primitive.neutral.950}" },
      "primary": { "$value": "{primitive.brand.600}" },
      "primary-foreground": { "$value": "{primitive.neutral.50}" },
      "secondary": { "$value": "{primitive.neutral.100}" },
      "secondary-foreground": { "$value": "{primitive.neutral.900}" },
      "muted": { "$value": "{primitive.neutral.100}" },
      "muted-foreground": { "$value": "{primitive.neutral.600}" },
      "accent": { "$value": "{primitive.neutral.100}" },
      "accent-foreground": { "$value": "{primitive.neutral.900}" },
      "destructive": { "$value": "{primitive.red.600}" },
      "destructive-foreground": { "$value": "{primitive.neutral.50}" },
      "border": { "$value": "{primitive.neutral.200}" },
      "input": { "$value": "{primitive.neutral.200}" },
      "ring": { "$value": "{primitive.brand.600}" }
    },
    "dark": {
      "background": { "$value": "{primitive.neutral.950}" },
      "foreground": { "$value": "{primitive.neutral.50}" },
      "card": { "$value": "{primitive.neutral.900}" },
      "card-foreground": { "$value": "{primitive.neutral.50}" },
      "popover": { "$value": "{primitive.neutral.900}" },
      "popover-foreground": { "$value": "{primitive.neutral.50}" },
      "primary": { "$value": "{primitive.brand.400}" },
      "primary-foreground": { "$value": "{primitive.neutral.950}" },
      "secondary": { "$value": "{primitive.neutral.800}" },
      "secondary-foreground": { "$value": "{primitive.neutral.50}" },
      "muted": { "$value": "{primitive.neutral.800}" },
      "muted-foreground": { "$value": "{primitive.neutral.400}" },
      "accent": { "$value": "{primitive.neutral.800}" },
      "accent-foreground": { "$value": "{primitive.neutral.50}" },
      "destructive": { "$value": "{primitive.red.500}" },
      "destructive-foreground": { "$value": "{primitive.neutral.50}" },
      "border": { "$value": "{primitive.neutral.800}" },
      "input": { "$value": "{primitive.neutral.800}" },
      "ring": { "$value": "{primitive.brand.400}" }
    }
  },
  "radius": {
    "$type": "dimension",
    "DEFAULT": { "$value": "0.625rem" }
  }
}
